<UserControl x:Class="AIRAC_Downloader_for_Euroscope.EuroscopeSettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AIRAC_Downloader_for_Euroscope"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <CheckBox Content="Enable"
                  Grid.Row="0"
                  Grid.Column="0"
                  Grid.ColumnSpan="2"/>


        <CheckBox x:Name="CheckCallsign"
                  Grid.Column="0"
                  Grid.Row="1"
                  HorizontalAlignment="Center"/>
        <TextBox x:Name="Callsign"
                 Grid.Column="1"
                 Grid.Row="1"
                 Margin="0,7,0,0"
                 materialDesign:HintAssist.Hint="Callsign"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

        <CheckBox x:Name="CheckRealName"
                  Grid.Column="0"
                  Grid.Row="2"
                  HorizontalAlignment="Center"/>
        <TextBox x:Name="Realname"
                 Grid.Column="1"
                 Grid.Row="2"
                 Margin="0,7,0,0"
                 materialDesign:HintAssist.Hint="Realname"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

        <CheckBox x:Name="CheckCertificate"
                  Grid.Column="0"
                  Grid.Row="3"
                  HorizontalAlignment="Center"/>
        <TextBox x:Name="Certificate"
                 Grid.Column="1"
                 Grid.Row="3"
                 Margin="0,7,0,0"
                 materialDesign:HintAssist.Hint="Certificate"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

        <CheckBox x:Name="CheckPassword"
                  Grid.Column="0"
                  Grid.Row="4"
                  HorizontalAlignment="Center"/>
        <PasswordBox x:Name="Password"
                     Grid.Column="1"
                     Grid.Row="4"
                     Margin="0,7,0,0"
                     materialDesign:HintAssist.Hint="Password"
                     materialDesign:TextFieldAssist.HasClearButton="True"
                     materialDesign:PasswordBoxAssist.Password="{Binding Password2, Mode=TwoWay}"
                     IsEnabled="{Binding ElementName=RevealPasswordFilledEnabled}"
                     Style="{StaticResource MaterialDesignOutlinedRevealPasswordBox}"/>



        <CheckBox x:Name="CheckFacility"
                  Grid.Column="0"
                  Grid.Row="5"
                  HorizontalAlignment="Center"/>
        <ComboBox x:Name="Facility"
                  Grid.Column="1"
                  Grid.Row="5"
                  Margin="0,7,0,0"
                  materialDesign:HintAssist.Hint="Facility"
                  Style="{StaticResource MaterialDesignOutlinedComboBox}">
            <ComboBoxItem Content="Observer"/>
            <ComboBoxItem Content="Flight Service Station"/>
            <ComboBoxItem Content="Clearance/Delivery"/>
            <ComboBoxItem Content="Ground"/>
            <ComboBoxItem Content="Tower"/>
            <ComboBoxItem Content="Approach/Departure"/>
            <ComboBoxItem Content="Center"/>
            <ComboBoxItem Content=""/>
        </ComboBox>

        <CheckBox x:Name="CheckRating"
          Grid.Column="0"
          Grid.Row="6"
          HorizontalAlignment="Center"/>
        <ComboBox x:Name="Rating"
          Grid.Column="1"
          Grid.Row="6"
          Margin="0,7,0,0"
          materialDesign:HintAssist.Hint="Rating"
          Style="{StaticResource MaterialDesignOutlinedComboBox}">
            <ComboBoxItem Content="Observer"/>
            <ComboBoxItem Content="Ground/Delivery (STU1)"/>
            <ComboBoxItem Content="Tower Controller (STU2)"/>
            <ComboBoxItem Content="TMA Controller (STU3)"/>
            <ComboBoxItem Content="Enroute Controller (CTR1)"/>
            <ComboBoxItem Content="Controller 2(not in use)"/>
            <ComboBoxItem Content="Senior controller (CTR3)"/>
            <ComboBoxItem Content="Instructor 1"/>
            <ComboBoxItem Content="Instructor 2"/>
            <ComboBoxItem Content="Instructor 3"/>
            <ComboBoxItem Content="Supervisor"/>
            <ComboBoxItem Content="Administrator"/>
            <ComboBoxItem Content=""/>
        </ComboBox>

        <CheckBox x:Name="CheckHoppie"
          Grid.Column="0"
          Grid.Row="7"
          HorizontalAlignment="Center"/>
        <PasswordBox x:Name="Hoppie"
             Grid.Column="1"
             Grid.Row="7"
             Margin="0,7,0,0"
             materialDesign:HintAssist.Hint="Hoppie"
             materialDesign:TextFieldAssist.HasClearButton="True"
             materialDesign:PasswordBoxAssist.Password="{Binding Password2, Mode=TwoWay}"
             IsEnabled="{Binding ElementName=RevealPasswordFilledEnabled}"
             Style="{StaticResource MaterialDesignOutlinedRevealPasswordBox}"/>

        <materialDesign:Card Grid.Row="8"
                             Grid.Column="0"
                             Grid.ColumnSpan="2"
                             Margin="0,7,0,0">
            <TabControl Width="300"
                        materialDesign:ColorZoneAssist.Mode="PrimaryLight"
                        Style="{StaticResource MaterialDesignFilledTabControl}">
                <TabItem Header="Sounds">
                    <TextBlock Margin="8"
                               Text="SecondaryLight Tab 1" />
                </TabItem>
                <TabItem Header="Plugins">
                    <TextBlock Margin="8"
                               Text="SecondaryLight Tab 2" />
                </TabItem>
            </TabControl>
        </materialDesign:Card>
    </Grid>
</UserControl>