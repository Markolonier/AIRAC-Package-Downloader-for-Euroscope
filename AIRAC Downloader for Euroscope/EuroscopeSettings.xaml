<UserControl x:Class="AIRAC_Downloader_for_Euroscope.EuroscopeSettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AIRAC_Downloader_for_Euroscope"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <CheckBox Content="Enable"
                  Grid.Row="0"
                  Grid.Column="0"
                  Grid.ColumnSpan="2"/>

        <!--Callsign-->
        <CheckBox x:Name="CheckCallsign"
                  Grid.Column="0"
                  Grid.Row="1"
                  Margin="0,7,0,0"
                  HorizontalAlignment="Center"/>
        <TextBox x:Name="Callsign"
                 Grid.Column="1"
                 Grid.Row="1"
                 Margin="0,7,0,0"
                 materialDesign:HintAssist.Hint="Callsign"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

        <!--Realname-->
        <CheckBox x:Name="CheckRealName"
                  Grid.Column="0"
                  Grid.Row="2"
                  Margin="0,7,0,0"
                  HorizontalAlignment="Center"/>
        <TextBox x:Name="Realname"
                 Grid.Column="1"
                 Grid.Row="2"
                 Margin="0,7,0,0"
                 materialDesign:HintAssist.Hint="Realname"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

        <!--Certificate-->
        <CheckBox x:Name="CheckCertificate"
                  Grid.Column="0"
                  Grid.Row="3"
                  Margin="0,7,0,0"
                  HorizontalAlignment="Center"/>
        <TextBox x:Name="Certificate"
                 Grid.Column="1"
                 Grid.Row="3"
                 Margin="0,7,0,0"
                 materialDesign:HintAssist.Hint="Certificate"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

        <!--Password-->
        <CheckBox x:Name="CheckPassword"
                  Grid.Column="0"
                  Grid.Row="4"
                  Margin="0,7,0,0"
                  HorizontalAlignment="Center"/>
        <PasswordBox x:Name="Password"
                     Grid.Column="1"
                     Grid.Row="4"
                     Margin="0,7,0,0"
                     materialDesign:HintAssist.Hint="Password"
                     materialDesign:TextFieldAssist.HasClearButton="True"
                     materialDesign:PasswordBoxAssist.Password="{Binding Password2, Mode=TwoWay}"
                     IsEnabled="{Binding ElementName=RevealPasswordFilledEnabled}"
                     Style="{StaticResource MaterialDesignOutlinedRevealPasswordBox}"/>

        <!--Facility-->
        <CheckBox x:Name="CheckFacility"
                  Grid.Column="0"
                  Grid.Row="5"
                  Margin="0,7,0,0"
                  HorizontalAlignment="Center"/>
        <ComboBox x:Name="Facility"
                  Grid.Column="1"
                  Grid.Row="5"
                  Margin="0,7,0,0"
                  materialDesign:HintAssist.Hint="Facility"
                  Style="{StaticResource MaterialDesignOutlinedComboBox}">
            <ComboBoxItem Content="Observer"/>
            <ComboBoxItem Content="Flight Service Station"/>
            <ComboBoxItem Content="Clearance/Delivery"/>
            <ComboBoxItem Content="Ground"/>
            <ComboBoxItem Content="Tower"/>
            <ComboBoxItem Content="Approach/Departure"/>
            <ComboBoxItem Content="Center"/>
            <ComboBoxItem Content=""/>
        </ComboBox>

        <!--Rating-->
        <CheckBox x:Name="CheckRating"
                  Grid.Column="0"
                  Grid.Row="6"
                  Margin="0,7,0,0"
                  HorizontalAlignment="Center"/>
        <ComboBox x:Name="Rating"
                  Grid.Column="1"
                  Grid.Row="6"
                  Margin="0,7,0,0"
                  materialDesign:HintAssist.Hint="Rating"
                  Style="{StaticResource MaterialDesignOutlinedComboBox}">
            <ComboBoxItem Content="Observer"/>
            <ComboBoxItem Content="Ground/Delivery (STU1)"/>
            <ComboBoxItem Content="Tower Controller (STU2)"/>
            <ComboBoxItem Content="TMA Controller (STU3)"/>
            <ComboBoxItem Content="Enroute Controller (CTR1)"/>
            <ComboBoxItem Content="Controller 2(not in use)"/>
            <ComboBoxItem Content="Senior controller (CTR3)"/>
            <ComboBoxItem Content="Instructor 1"/>
            <ComboBoxItem Content="Instructor 2"/>
            <ComboBoxItem Content="Instructor 3"/>
            <ComboBoxItem Content="Supervisor"/>
            <ComboBoxItem Content="Administrator"/>
            <ComboBoxItem Content=""/>
        </ComboBox>
        
        <!--Hoppie-->
        <CheckBox x:Name="CheckHoppie"
                  Grid.Column="0"
                  Grid.Row="7"
                  Margin="0,7,0,0"
                  HorizontalAlignment="Center"/>
        <PasswordBox x:Name="Hoppie"
                     Grid.Column="1"
                     Grid.Row="7"
                     Margin="0,7,0,0"
                     materialDesign:HintAssist.Hint="Hoppie"
                     materialDesign:TextFieldAssist.HasClearButton="True"
                     materialDesign:PasswordBoxAssist.Password="{Binding Password2, Mode=TwoWay}"
                     IsEnabled="{Binding ElementName=RevealPasswordFilledEnabled}"
                     Style="{StaticResource MaterialDesignOutlinedRevealPasswordBox}"/>

        <materialDesign:Card Grid.Row="8"
                             Grid.Column="0"
                             Grid.ColumnSpan="3"
                             Margin="0,7,0,0">
            <TabControl materialDesign:ColorZoneAssist.Mode="PrimaryLight"
                        Style="{StaticResource MaterialDesignFilledUniformTabControl}">
                
                <!--Sounds Tab-->
                <TabItem Header="Sounds">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <!--Headerthingy-->
                        <TextBlock Text="Add custom Sounds" Grid.Row="0" Grid.Column="0" Margin="0,7,0,0" FontSize="15" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <Button x:Name="addSoundRow"  Grid.Row="0" Grid.Column="1" Margin="30,7,0,0" HorizontalAlignment="Right">
                            <materialDesign:PackIcon Kind="TableRowPlusBefore" Height="24" Width="24"/>
                        </Button>
                        <Button x:Name="RemoveSoundRow"  Grid.Row="0" Grid.Column="2" Margin="7,7,0,0" HorizontalAlignment="Right">
                            <materialDesign:PackIcon Kind="TableRowRemove" Height="24" Width="24"/>
                        </Button>
                        <!--Datagrid-->
                        <DataGrid x:Name="SoundsList"
                                        Grid.Row="1"
                                        Grid.Column="0"
                                        Grid.ColumnSpan="3"
                                        Margin="0,7,0,0"
                                        CanUserAddRows="True">
                            <DataGrid.Columns>
                                <DataGridCheckBoxColumn Header="Select"/>
                                <DataGridTextColumn Header="Soundfile"/>
                                <DataGridComboBoxColumn Header="Soundtype"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>
                
                <!--Plugins Tab-->
                <TabItem Header="Plugins">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <!--Headerthingy-->
                        <TextBlock Text="Add custom Plugins" Grid.Row="0" Grid.Column="0" Margin="0,7,0,0" FontSize="15" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <Button x:Name="addPluginRow"  Grid.Row="0" Grid.Column="1" Margin="30,7,0,0" HorizontalAlignment="Right">
                            <materialDesign:PackIcon Kind="TableRowPlusBefore" Height="24" Width="24"/>
                        </Button>

                        <Button x:Name="RemovePluginRow"  Grid.Row="0" Grid.Column="2" Margin="7,7,0,0" HorizontalAlignment="Right">
                            <materialDesign:PackIcon Kind="TableRowRemove" Height="24" Width="24"/>
                        </Button>
                        <!--Datagrid-->
                        <DataGrid x:Name="PluginsList"
                                  Grid.Row="1"
                                  Grid.Column="0"
                                  Grid.ColumnSpan="3"
                                  Margin="0,7,0,0"
                                  CanUserAddRows="True">
                            <DataGrid.Columns>
                                <DataGridCheckBoxColumn Header="Select"/>
                                <DataGridTextColumn Header="Pluginfile (.dll)"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>
            </TabControl>
        </materialDesign:Card>
    </Grid>
</UserControl>