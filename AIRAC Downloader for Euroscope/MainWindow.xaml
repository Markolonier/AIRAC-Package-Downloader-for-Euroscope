<Window x:Class="AIRAC_Downloader_for_Euroscope.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AIRAC_Downloader_for_Euroscope"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Style="{StaticResource MaterialDesignWindow}"
        mc:Ignorable="d" WindowStyle="SingleBorderWindow"
        Title="AIRAC Downloader for Euroscope" Height="450" Width="800" MinWidth="550" MinHeight="600" ResizeMode="CanResize">
    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="1" CornerRadius="0" CaptionHeight="0" UseAeroCaptionButtons="False" ResizeBorderThickness="7"/>
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <materialDesign:ColorZone Height="65" Padding="12" Grid.Row="0" MouseDown="Window_MouseLeftButtonDown" MouseUp="Window_MouseUp" MouseMove="Window_MouseMove" ClipToBounds="False" Mode="PrimaryDark">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="AIRAC Downloader for Euroscope" Grid.Column="0" Margin="8,0,0,0" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <Button Style="{StaticResource MaterialDesignToolButton}" Grid.Column="2" Margin="5,0" Click="MinimizeWindow_Click">
                    <materialDesign:PackIcon Kind="WindowMinimize" Foreground="White" Width="24" Height="24"/>
                </Button>
                <Button Style="{StaticResource MaterialDesignToolButton}" Grid.Column="3" Margin="5,0" Click="MaximizeOrUnMaximizeWindow_Click">
                    <materialDesign:PackIcon x:Name="MaximizeOrUnMaximizeWindowButtonIcon" Kind="WindowMaximize" Foreground="White" Width="24" Height="24"/>
                </Button>
                <Button Style="{StaticResource MaterialDesignToolButton}" Grid.Column="4" Click="CloseWindow_Click">
                    <materialDesign:PackIcon Kind="WindowClose" Foreground="White" Width="24" Height="24"/>
                </Button>
            </Grid>
        </materialDesign:ColorZone>
        <TabControl materialDesign:NavigationRailAssist.ShowSelectionBackground="True"
                    materialDesign:ColorZoneAssist.Mode="PrimaryMid"
                    Style="{StaticResource MaterialDesignNavigationRailTabControl}"
                    Grid.Column="0"
                    Grid.Row="1">
            <TabItem Width="Auto" Height="Auto">
                <TabItem.Header>
                    <StackPanel Width="auto" Height="auto" Margin="10">
                        <materialDesign:PackIcon Width="24"
                                                 Height="24"
                                                 HorizontalAlignment="Center"
                                                 Kind="Radar"/>
                        <TextBlock HorizontalAlignment="Center" Text="Euroscope"/>
                    </StackPanel>
                </TabItem.Header>
                <local:EuroscopeSettings Height="Auto" Width="Auto"/>
            </TabItem>

            <TabItem Width="auto" Height="auto">
                <TabItem.Header>
                    <StackPanel Width="auto" Height="auto" Margin="10">
                        <materialDesign:PackIcon Width="24"
                                                 Height="24"
                                                 HorizontalAlignment="Center"
                                                 Kind="PhoneDial"/>
                        <TextBlock HorizontalAlignment="Center" Text="VCCS"/>
                    </StackPanel>
                </TabItem.Header>
            </TabItem>

            <TabItem Width="auto" Height="auto">
                <TabItem.Header>
                    <StackPanel Width="auto" Height="auto" Margin="10">
                        <materialDesign:PackIcon Width="24"
                                                 Height="24"
                                                 HorizontalAlignment="Center"
                                                 Kind="DatabaseArrowDown"/>
                        <TextBlock HorizontalAlignment="Center" Text="AeroNav"/>
                    </StackPanel>
                </TabItem.Header>
            </TabItem>
        </TabControl>
        <Button Grid.Row="2" Height="57">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="DownloadBox" Height="30" Width="30" VerticalAlignment="Center"/>
                <TextBlock Text="Download" Margin="8,10,0,10" Style="{StaticResource MaterialDesignHeadline5TextBlock}"/>
            </StackPanel>
        </Button>
    </Grid>
</Window>
