<UserControl x:Class="AIRAC_Downloader_for_Euroscope.AeroNavSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AIRAC_Downloader_for_Euroscope"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:mde="clr-namespace:MaterialDesignExtensions.Controls;assembly=MaterialDesignExtensions"
             mc:Ignorable="d" 
             Loaded="loaded"
             d:DesignHeight="450" d:DesignWidth="800">
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        

        <!--VACC-->
        <ComboBox x:Name="VACC"
                  Grid.Column="0"
                  Grid.ColumnSpan="4"
                  Grid.Row="0"
                  Margin="0,7,0,0"
                  materialDesign:HintAssist.Hint="VACC"
                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                  ItemsSource="{Binding VaccList}"
                  SelectionChanged="changedVaccSelection"/>
        
        <!--Package-->
        <ComboBox x:Name="Package"
                  Grid.Column="0"
                  Grid.ColumnSpan="4"
                  Grid.Row="1"
                  Margin="0,7,0,0"
                  materialDesign:HintAssist.Hint="Package"
                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                  ItemsSource="{Binding PackageList}"
                  SelectionChanged="changedPackageSelection"/>

        <!--Local Package Folder-->
        <Grid Grid.Column="0"
              Grid.ColumnSpan="4"
              Grid.Row="2"
              Margin="0,7,0,0">
            <Grid.ColumnDefinitions> <!--for Folder and Selection Button-->
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <!--Local Folder Textbox-->
            <TextBox x:Name="PackageFolder"
                     Grid.Column="0"
                     materialDesign:HintAssist.Hint="Package Folder"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     IsEnabled="False" TextChanged="scanNewOfflinePackage"/>
            <!--Local Folder Selector Button-->
            <Button x:Name="PackageSelector"
                    Grid.Column="1"
                    Margin="7,0,0,0" Click="selectNewLocalFolder">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="FolderOpen" Height="24" Width="24" VerticalAlignment="Center"/>
                    <TextBlock Text="Select local folder" Margin="10,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>
        
        <!--Online Package Info-->
        <StackPanel Grid.Column="0"
                    Grid.Row="3"
                    Margin="0,7,0,0"
                    Orientation="Horizontal">
            <materialDesign:PackIcon Kind="Cloud" Height="24" Width="24" VerticalAlignment="Center"/>
            <TextBlock Margin="7,0,0,0"
                       FontSize="15"
                       VerticalAlignment="Center"
                       Text="Online Version Info:"
                       Style="{StaticResource MaterialDesignOverlineTextBlock}"/>
        </StackPanel>
        <!--AIRAC-->
        <TextBlock x:Name="OnlineAirac"
                   Grid.Column="1"
                   Grid.Row="3"
                   Margin="30,7,0,0"
                   FontSize="15"
                   VerticalAlignment="Center"
                   Text="AIRAC: "/>
        <!--Version-->
        <TextBlock x:Name="OnlineVersion"
                   Grid.Column="2"
                   Grid.Row="3"
                   Margin="30,7,0,0"
                   FontSize="15"
                   VerticalAlignment="Center"
                   Text="Version: "/>
        <!--Relased-->
        <TextBlock x:Name="OnlineReleased"
                   Grid.Column="3"
                   Grid.Row="3"
                   Margin="30,7,0,0"
                   FontSize="15"
                   VerticalAlignment="Center"
                   Text="Released: "/>
        
        <!--Offline Package Info-->
        <!--Online Package Info-->
        <StackPanel Grid.Column="0"
                    Grid.Row="4"
                    Margin="0,7,0,0"
                    Orientation="Horizontal">
            <materialDesign:PackIcon Kind="Folder" Height="24" Width="24" VerticalAlignment="Center"/>
            <TextBlock Margin="7,0,0,0"
                       FontSize="15"
                       VerticalAlignment="Center"
                       Text="Offline Version Info:"
                       Style="{StaticResource MaterialDesignOverlineTextBlock}"/>
        </StackPanel>
        <!--AIRAC-->
        <TextBlock x:Name="OfflineAirac"
                   Grid.Column="1"
                   Grid.Row="4"
                   Margin="30,7,0,0"
                   FontSize="15"
                   VerticalAlignment="Center"
                   Text="AIRAC: "/>
        <!--Version-->
        <TextBlock x:Name="OfflineVersion"
                   Grid.Column="2"
                   Grid.Row="4"
                   Margin="30,7,0,0"
                   FontSize="15"
                   VerticalAlignment="Center"
                   Text="Version: "/>
        <!--Relased-->
        <TextBlock x:Name="OfflineReleased"
                   Grid.Column="3"
                   Grid.Row="4"
                   Margin="30,7,0,0"
                   FontSize="15"
                   VerticalAlignment="Center"
                   Text="Released: "/>

        <!--Save Configuration-->
        <Button x:Name="SaveConfig"
                Grid.Column="0"
                Grid.ColumnSpan="4"
                Grid.Row="5"
                Margin="0,30,0,0" Click="SaveUserConfig">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="FileCogOutline" Height="24" Width="24" VerticalAlignment="Center"/>
                <TextBlock Text="Save Package Configuration" Margin="10,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </Button>

    </Grid>
</UserControl>
