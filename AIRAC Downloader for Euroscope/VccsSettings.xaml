<UserControl x:Class="AIRAC_Downloader_for_Euroscope.VccsSettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AIRAC_Downloader_for_Euroscope"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <CheckBox Content="Enable all"
                  Grid.Row="0"
                  Grid.Column="0"
                  Grid.ColumnSpan="2"/> 
        
        <!--Nickname-->
        <CheckBox x:Name="CheckNickname"
                  Grid.Column="0"
                  Grid.Row="1"
                  Margin="0,7,0,0"
                  HorizontalAlignment="Center"/>
        <TextBox x:Name="Nickname"
                 Grid.Column="1"
                 Grid.Row="1"
                 Margin="0,7,0,0"
                 materialDesign:HintAssist.Hint="Nickname"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
        
        <!--G2A PTT-->
        <CheckBox x:Name="CheckG2A"
                  Grid.Column="0"
                  Grid.Row="2"
                  Margin="0,7,0,0"
                  HorizontalAlignment="Center"/>
        <Button x:Name="G2A"
                Content="G2A PTT: "
                Grid.Column="1"
                Grid.Row="2"
                Margin="0,7,0,0"/>
        
        <!--G2G PTT-->
        <CheckBox x:Name="CheckG2G"
                  Grid.Column="0"
                  Grid.Row="3"
                  Margin="0,7,0,0"
                  HorizontalAlignment="Center"/>
        <Button x:Name="G2G"
                Content="G2G PTT: "
                Grid.Column="1"
                Grid.Row="3"
                Margin="0,7,0,0"/>
        
        <!--Capture Mode-->
        <CheckBox x:Name="CheckCaptureMode"
                  Grid.Column="0"
                  Grid.Row="4"
                  Margin="0,7,0,0"
                  HorizontalAlignment="Center"/>
        <ComboBox x:Name="CaptureMode"
                  Grid.Column="1"
                  Grid.Row="4"
                  Margin="0,7,0,0"
                  materialDesign:HintAssist.Hint="Capture Mode"
                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                  ItemsSource="{Binding InputAudioAPIs}"/>
        
        <!--Capture Device-->
        <CheckBox x:Name="CheckCaptureDevice"
                  Grid.Column="0"
                  Grid.Row="5"
                  Margin="0,7,0,0"
                  HorizontalAlignment="Center"/>
        <ComboBox x:Name="CaptureDevice"
                  Grid.Column="1"
                  Grid.Row="5"
                  Margin="0,7,0,0"
                  materialDesign:HintAssist.Hint="Capture Device"
                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                  ItemsSource="{Binding InputAudioDevices}"/>
        
        <!--Playback Mode-->
        <CheckBox x:Name="CheckPlaybackMode"
                  Grid.Column="0"
                  Grid.Row="6"
                  Margin="0,7,0,0"
                  HorizontalAlignment="Center"/>
        <ComboBox x:Name="PlaybackMode"
                  Grid.Column="1"
                  Grid.Row="6"
                  Margin="0,7,0,0"
                  materialDesign:HintAssist.Hint="Playback Mode"
                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                  ItemsSource="{Binding OutputAudioAPIs}"/>
        
        <!--Playback Device-->
        <CheckBox x:Name="CheckPlaybackDevice"
                  Grid.Column="0"
                  Grid.Row="7"
                  Margin="0,7,0,0"
                  HorizontalAlignment="Center"/>
        <ComboBox x:Name="PlaybackDevice"
                  Grid.Column="1"
                  Grid.Row="7"
                  Margin="0,7,0,0"
                  materialDesign:HintAssist.Hint="Playback Device"
                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                  ItemsSource="{Binding OutputAudioDevices}"/>
    </Grid>
</UserControl>
